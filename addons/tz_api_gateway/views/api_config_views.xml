<odoo>
    <record id="view_tz_api_config_tree" model="ir.ui.view">
        <field name="name">tz.api.config.tree</field>
        <field name="model">tz.api.config</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="source_name"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_tz_api_config_form" model="ir.ui.view">
        <field name="name">tz.api.config.form</field>
        <field name="model">tz.api.config</field>
        <field name="arch" type="xml">
            <form string="API Configuration">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                        <field name="api_key" password="True"/>
                        <field name="source_name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tz_api_config" model="ir.actions.act_window">
        <field name="name">API Configurations</field>
        <field name="res_model">tz.api.config</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>