<odoo>

    <record id="view_tz_lead_config_tree" model="ir.ui.view">
        <field name="name">tz.lead.config.tree</field>
        <field name="model">tz.lead.config</field>
        <field name="arch" type="xml">
            <tree string="Lead Configurations">
                <field name="name"/>
                <field name="company_id"/>
                <field name="supervisor_display_name"/>
                <field name="agent_display_name"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_tz_lead_config_form" model="ir.ui.view">
        <field name="name">tz.lead.config.form</field>
        <field name="model">tz.lead.config</field>
        <field name="arch" type="xml">
            <form string="Lead Configuration">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="company_id"/>
                        <field name="active"/>
                    </group>

                    <notebook>

                        <page string="CRM Routing">
                            <notebook>
                                <page string="Managers">
                                    <group>
                                        <field name="default_supervisor_id"
                                               domain="[('groups_id', 'in', [%(tz_crm_base.group_tz_crm_manager)d])]"/>
                                        <field name="supervisor_display_name"
                                               string="Selected Manager - Team"
                                               readonly="1"/>
                                    </group>
                                </page>

                                <page string="Agents">
                                    <group>
                                        <field name="default_agent_id"
                                               domain="[('groups_id', 'in', [%(tz_crm_base.group_tz_crm_agent)d]), ('groups_id', 'not in', [%(tz_crm_base.group_tz_crm_manager)d])]"/>
                                        <field name="agent_display_name"
                                               string="Selected Agent - Team"
                                               readonly="1"/>
                                    </group>
                                </page>
                            </notebook>
                        </page>

                        <page string="Integrations">
                            <field name="integration_ids">
                                <tree editable="bottom">
                                    <field name="active"/>
                                    <field name="name"/>
                                    <field name="source_type"/>
                                    <field name="integration_code"/>
                                    <field name="api_key" password="True"/>
                                    <field name="website_domain"/>
                                    <field name="meta_page_id"/>
                                    <field name="meta_campaign_id"/>
                                    <field name="whatsapp_phone_number_id"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Notes">
                            <field name="notes"/>
                        </page>

                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tz_lead_config" model="ir.actions.act_window">
        <field name="name">Lead Configurations</field>
        <field name="res_model">tz.lead.config</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_tz_lead_config"
              name="Lead Configurations"
              parent="tz_crm_base.menu_tz_crm_root"
              action="action_tz_lead_config"
              groups="tz_crm_base.group_tz_crm_admin"
              sequence="120"/>

</odoo>