<odoo>
    <record id="res_config_settings_view_form_tz_global_compliance" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.tz.global.compliance</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='account']" position="inside">
                <block title="Techzilla Compliance" name="tz_global_compliance_block" groups="account.group_account_manager,base.group_system">
                    <setting string="Enable UAE Compliance">
                        <field name="tz_enable_uae_compliance"/>
                    </setting>
                    <setting string="Compliance Country Mode">
                        <field name="tz_compliance_country_mode"/>
                    </setting>
                    <setting string="Saudi ZATCA Checklist" help="Placeholder checklist only.">
                        <field name="tz_zatca_readiness_note"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
