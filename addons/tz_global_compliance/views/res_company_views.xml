<odoo>
    <record id="view_company_form_tz_global_compliance" model="ir.ui.view">
        <field name="name">res.company.form.tz.global.compliance</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Techzilla Compliance" groups="account.group_account_manager,base.group_system">
                    <group>
                        <field name="tz_enable_uae_compliance"/>
                        <field name="tz_compliance_country_mode"/>
                        <field name="vat" string="Company TRN"/>
                        <field name="tz_zatca_readiness_note" attrs="{'invisible': [('tz_compliance_country_mode','!=','saudi')]}"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
