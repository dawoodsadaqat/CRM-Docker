<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =========================================================
         TREE VIEW EXTENSION
    ========================================================== -->
    <record id="view_hr_attendance_tree_tz_geo" model="ir.ui.view">
        <field name="name">hr.attendance.tree.tz.geo</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.view_attendance_tree"/>
        <field name="arch" type="xml">

            <xpath expr="//tree" position="inside">

                <field name="tz_gps_status" optional="show"/>

                <field name="tz_location_age_minutes"
                       optional="hide"/>

                <field name="tz_distance_between_checkin_checkout"
                       optional="show"/>

            </xpath>

        </field>
    </record>


    <!-- =========================================================
         FORM VIEW EXTENSION
    ========================================================== -->
    <record id="view_hr_attendance_form_tz_geo" model="ir.ui.view">
        <field name="name">hr.attendance.form.tz.geo</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.hr_attendance_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet" position="inside">

                <group string="GPS Attendance">

                    <group>

                        <field name="tz_check_in_latitude"/>
                        <field name="tz_check_in_longitude"/>

                        <field name="tz_check_out_latitude"/>
                        <field name="tz_check_out_longitude"/>

                    </group>

                    <group>

                        <field name="tz_gps_status"/>

                        <field name="tz_location_age_minutes"/>

                        <field name="tz_distance_between_checkin_checkout"/>

                    </group>

                </group>

                <group string="Map Links">

                    <group>

                        <field name="tz_check_in_map_url"
                               widget="url"
                               readonly="1"/>

                        <field name="tz_check_out_map_url"
                               widget="url"
                               readonly="1"/>

                    </group>

                </group>

            </xpath>

        </field>
    </record>


    <!-- =========================================================
         SEARCH/FILTER VIEW EXTENSION
    ========================================================== -->
    <record id="view_hr_attendance_filter_tz_geo" model="ir.ui.view">
        <field name="name">hr.attendance.search.tz.geo</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id" ref="hr_attendance.hr_attendance_view_filter"/>
        <field name="arch" type="xml">

            <xpath expr="//search" position="inside">

                <separator/>

                <filter
                    name="filter_gps_suspicious"
                    string="GPS Suspicious"
                    domain="[('tz_gps_status', '!=', 'valid')]"
                />

                <filter
                    name="filter_fake_attendance"
                    string="Fake Attendance"
                    domain="[('tz_distance_between_checkin_checkout', '=', 0)]"
                />

            </xpath>

        </field>
    </record>

</odoo>