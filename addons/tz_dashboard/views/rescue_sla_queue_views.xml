<odoo>
    <record id="view_rescue_sla_queue_tree" model="ir.ui.view">
        <field name="name">rescue.sla.queue.tree</field>
        <field name="model">crm.lead</field>
        <field name="arch" type="xml">
            <tree string="Rescue SLA Queue"
                  decoration-warning="sla_rescue_status == 'in_progress'"
                  decoration-danger="sla_rescue_status == 'breached'">

                <field name="name"/>
                <field name="user_id" string="Assigned Agent"/>
                <field name="sla_rescue_user_id" string="Rescue Owner"/>
                <field name="sla_rescue_assigned_date"/>
                <field name="sla_rescue_deadline"/>
                <field name="sla_rescue_status"/>
                <field name="sla_status"/>
                <field name="conversion_stage"/>

            </tree>
        </field>
    </record>

    <record id="action_rescue_sla_queue" model="ir.actions.act_window">
        <field name="name">Rescue SLA Queue</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_rescue_sla_queue_tree"/>
        <field name="domain">
            [('sla_rescue_status','=','in_progress')]
        </field>
    </record>

    <menuitem id="menu_rescue_sla_queue"
              name="Rescue SLA Queue"
              parent="tz_crm_base.menu_tz_crm_root"
              action="action_rescue_sla_queue"
              groups="tz_crm_base.group_tz_crm_agent,tz_crm_base.group_tz_crm_manager,tz_crm_base.group_tz_crm_admin"
              sequence="89"/>
</odoo>