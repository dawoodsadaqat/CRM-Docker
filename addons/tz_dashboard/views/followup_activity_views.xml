<odoo>
    <record id="view_followup_reminder_tree" model="ir.ui.view">
        <field name="name">followup.reminder.tree</field>
        <field name="model">mail.activity</field>
        <field name="arch" type="xml">
            <tree string="Follow-up Reminders">
                <field name="date_deadline"/>
                <field name="summary"/>
                <field name="res_name"/>
                <field name="user_id"/>
                <field name="activity_type_id"/>
            </tree>
        </field>
    </record>

    <record id="action_followup_reminders" model="ir.actions.act_window">
        <field name="name">Follow-up Reminders</field>
        <field name="res_model">mail.activity</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_followup_reminder_tree"/>
        <field name="domain">
            [('summary','=','Follow-up Reminder'), ('res_model','=','crm.lead')]
        </field>
    </record>

    <menuitem id="menu_followup_reminders"
              name="Follow-up Reminders"
              parent="tz_crm_base.menu_tz_crm_root"
              action="action_followup_reminders"
              groups="tz_crm_base.group_tz_crm_agent,tz_crm_base.group_tz_crm_manager,tz_crm_base.group_tz_crm_admin"
              sequence="85"/>
</odoo>