<odoo>
    <record id="group_tz_crm_agent" model="res.groups">
        <field name="name">CRM Agent</field>
        <field name="category_id" ref="base.module_category_sales_crm"/>
    </record>

    <record id="group_tz_crm_manager" model="res.groups">
        <field name="name">CRM Manager</field>
        <field name="category_id" ref="base.module_category_sales_crm"/>
        <field name="implied_ids" eval="[(4, ref('group_tz_crm_agent'))]"/>
    </record>

    <record id="group_tz_crm_admin" model="res.groups">
        <field name="name">CRM Admin</field>
        <field name="category_id" ref="base.module_category_sales_crm"/>
        <field name="implied_ids" eval="[(4, ref('group_tz_crm_manager'))]"/>
    </record>
</odoo>