<odoo>
    <record id="view_tz_property_unit_tree" model="ir.ui.view">
        <field name="name">tz.property.unit.tree</field>
        <field name="model">tz.property.unit</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="unit_number"/>
                <field name="project_id"/>
                <field name="building_id"/>
                <field name="area"/>
                <field name="property_type"/>
                <field name="bedrooms"/>
                <field name="size_sqft"/>
                <field name="sale_price"/>
                <field name="rent_price"/>
                <field name="availability"/>
                <field name="assigned_agent_id"/>
            </tree>
        </field>
    </record>

    <record id="view_tz_property_unit_form" model="ir.ui.view">
        <field name="name">tz.property.unit.form</field>
        <field name="model">tz.property.unit</field>
        <field name="arch" type="xml">
            <form string="Property Unit">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="unit_number"/>
                            <field name="project_id"/>
                            <field name="building_id"/>
                            <field name="developer_id" readonly="1"/>
                            <field name="area" />
                        </group>
                        <group>
                            <field name="property_type"/>
                            <field name="bedrooms"/>
                            <field name="bathrooms"/>
                            <field name="size_sqft"/>
                            <field name="availability"/>
                        </group>
                    </group>

                    <group string="Pricing">
                        <field name="sale_price"/>
                        <field name="rent_price"/>
                        <field name="display_price" readonly="1"/>
                    </group>

                    <group string="Ownership / Assignment">
                        <field name="owner_id"/>
                        <field name="assigned_agent_id"/>
                        <field name="active"/>
                    </group>

                    <notebook>
                        <page string="Listings">
                            <field name="listing_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="listing_type"/>
                                    <field name="listing_price"/>
                                    <field name="status"/>
                                    <field name="published_date"/>
                                    <field name="portal_reference"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tz_property_unit_search" model="ir.ui.view">
        <field name="name">tz.property.unit.search</field>
        <field name="model">tz.property.unit</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="unit_number"/>
                <field name="project_id"/>
                <field name="building_id"/>
                <field name="area"/>
                <field name="property_type"/>

                <filter string="Available" name="available" domain="[('availability','=','available')]"/>
                <filter string="Reserved" name="reserved" domain="[('availability','=','reserved')]"/>
                <filter string="Sold" name="sold" domain="[('availability','=','sold')]"/>
                <filter string="Rented" name="rented" domain="[('availability','=','rented')]"/>

                <group expand="0" string="Group By">
                    <filter string="Project" name="group_project" context="{'group_by':'project_id'}"/>
                    <filter string="Building" name="group_building" context="{'group_by':'building_id'}"/>
                    <filter string="Area" name="group_area" context="{'group_by':'area'}"/>
                    <filter string="Property Type" name="group_property_type" context="{'group_by':'property_type'}"/>
                    <filter string="Availability" name="group_availability" context="{'group_by':'availability'}"/>
                    <filter string="Agent" name="group_agent" context="{'group_by':'assigned_agent_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_tz_property_unit" model="ir.actions.act_window">
        <field name="name">Units</field>
        <field name="res_model">tz.property.unit</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_tz_property_unit_search"/>
    </record>
</odoo>