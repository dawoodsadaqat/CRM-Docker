<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Admin sees everything -->
    <record id="rule_tz_user_location_admin" model="ir.rule">
        <field name="name">Admin can see all latest locations</field>
        <field name="model_id" ref="model_tz_user_location"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>

    <record id="rule_tz_location_history_admin" model="ir.rule">
        <field name="name">Admin can see all location history</field>
        <field name="model_id" ref="model_tz_user_location_history"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>

    <!-- Sales Manager / Supervisor sees own + team members -->
    <record id="rule_tz_user_location_sales_manager" model="ir.rule">
        <field name="name">Supervisor can see team latest locations</field>
        <field name="model_id" ref="model_tz_user_location"/>
        <field name="domain_force">['|', ('user_id', '=', user.id), ('supervisor_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_manager'))]"/>
    </record>

    <record id="rule_tz_location_history_sales_manager" model="ir.rule">
        <field name="name">Supervisor can see team location history</field>
        <field name="model_id" ref="model_tz_user_location_history"/>
        <field name="domain_force">['|', ('user_id', '=', user.id), ('supervisor_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_manager'))]"/>
    </record>

    <!-- Normal agent sees own only -->
    <record id="rule_tz_user_location_own" model="ir.rule">
        <field name="name">Agent can see own latest location</field>
        <field name="model_id" ref="model_tz_user_location"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="rule_tz_location_history_own" model="ir.rule">
        <field name="name">Agent can see own location history</field>
        <field name="model_id" ref="model_tz_user_location_history"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

</odoo>