<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="rule_tz_user_location_admin" model="ir.rule">
        <field name="name">Live Tracking Admin All</field>
        <field name="model_id" ref="model_tz_user_location"/>
        <field name="groups" eval="[(4, ref('tz_crm_base.group_tz_crm_admin'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="rule_tz_user_location_manager_team" model="ir.rule">
        <field name="name">Live Tracking Manager Team</field>
        <field name="model_id" ref="model_tz_user_location"/>
        <field name="groups" eval="[(4, ref('tz_crm_base.group_tz_crm_manager'))]"/>
        <field name="domain_force">
            [
                '|',
                    ('user_id', '=', user.id),
                    ('team_ids.user_id', '=', user.id)
            ]
        </field>
    </record>

</odoo>