<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="action_tz_my_tracking" model="ir.actions.client">
        <field name="name">My Tracking</field>
        <field name="tag">tz_live_tracking_panel</field>
    </record>

    <record id="action_tz_user_location" model="ir.actions.act_window">
        <field name="name">Team / User Locations</field>
        <field name="res_model">tz.user.location</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_tz_user_location_history" model="ir.actions.act_window">
        <field name="name">Location History</field>
        <field name="res_model">tz.user.location.history</field>
        <field name="view_mode">tree</field>
    </record>

    

  <menuitem
    id="menu_tz_my_tracking"
    name="My Tracking"
    parent="crm.crm_menu_root"
    action="action_tz_my_tracking"
    sequence="95"
/>

<menuitem
    id="menu_tz_user_location"
    name="Team / User Locations"
    parent="crm.crm_menu_root"
    action="action_tz_user_location"
    sequence="96"
/>

<menuitem
    id="menu_tz_user_location_history"
    name="Location History"
    parent="crm.crm_menu_root"
    action="action_tz_user_location_history"
    sequence="97"
/>

</odoo>