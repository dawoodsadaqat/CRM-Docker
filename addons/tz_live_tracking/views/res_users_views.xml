<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_users_form_tz_live_tracking" model="ir.ui.view">
        <field name="name">res.users.form.tz.live.tracking</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Live Tracking">
                    <group>
                        <field name="tz_tracking_enabled"/>
                        <field name="tz_tracking_status" readonly="1"/>
                        <field name="tz_last_latitude" readonly="1"/>
                        <field name="tz_last_longitude" readonly="1"/>
                        <field name="tz_last_accuracy" readonly="1"/>
                        <field name="tz_last_seen" readonly="1"/>
                        <field name="tz_location_token" readonly="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>