<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_tz_user_location_tree" model="ir.ui.view">
        <field name="name">tz.user.location.tree</field>
        <field name="model">tz.user.location</field>
        <field name="arch" type="xml">
            <tree string="Live Tracking">
                <field name="user_id"/>
                <field name="team_ids" widget="many2many_tags"/>
                <field name="latitude"/>
                <field name="longitude"/>
                <field name="accuracy"/>
                <field name="battery_level"/>
                <field name="last_seen"/>
                <field name="is_online"/>
                <field name="map_url" widget="url"/>
            </tree>
        </field>
    </record>

    <record id="view_tz_user_location_form" model="ir.ui.view">
        <field name="name">tz.user.location.form</field>
        <field name="model">tz.user.location</field>
        <field name="arch" type="xml">
            <form string="Live Tracking">
                <sheet>
                    <group>
                        <field name="user_id"/>
                        <field name="team_ids" widget="many2many_tags" readonly="1"/>
                        <field name="latitude"/>
                        <field name="longitude"/>
                        <field name="accuracy"/>
                        <field name="battery_level"/>
                        <field name="last_seen"/>
                        <field name="is_online"/>
                        <field name="map_url" widget="url"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
<record id="view_users_form_live_tracking_token" model="ir.ui.view">
    <field name="name">res.users.form.live.tracking.token</field>
    <field name="model">res.users</field>
    <field name="inherit_id" ref="base.view_users_form"/>
    <field name="arch" type="xml">

        <xpath expr="//page[@name='preferences']" position="after">
            <page string="Live Tracking" groups="tz_crm_base.group_tz_crm_admin">
                <group>
                    <field name="tz_location_tracking_enabled"/>
                    <field name="tz_location_token" readonly="1"/>
                    <button name="action_generate_location_token"
                            string="Generate Location Token"
                            type="object"
                            class="btn-primary"/>
                </group>
            </page>
        </xpath>

    </field>
</record>
    <record id="action_tz_user_location" model="ir.actions.act_window">
        <field name="name">Live Tracking</field>
        <field name="res_model">tz.user.location</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem
        id="menu_tz_live_tracking"
        name="Live Tracking"
        parent="tz_crm_base.menu_tz_crm_root"
        action="action_tz_user_location"
        sequence="90"
        groups="tz_crm_base.group_tz_crm_admin,tz_crm_base.group_tz_crm_manager"
    />

</odoo>