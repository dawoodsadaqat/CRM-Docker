<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_tz_live_tracking_config_form" model="ir.ui.view">
        <field name="name">tz.live.tracking.config.form</field>
        <field name="model">tz.live.tracking.config</field>
        <field name="arch" type="xml">
            <form string="Live Tracking Settings">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="tracking_enabled"/>
                        <field name="update_interval_seconds"/>
                        <field name="online_threshold_seconds"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tz_live_tracking_config_tree" model="ir.ui.view">
        <field name="name">tz.live.tracking.config.tree</field>
        <field name="model">tz.live.tracking.config</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="tracking_enabled"/>
                <field name="update_interval_seconds"/>
                <field name="online_threshold_seconds"/>
            </tree>
        </field>
    </record>

    <record id="action_tz_live_tracking_config" model="ir.actions.act_window">
        <field name="name">Live Tracking Settings</field>
        <field name="res_model">tz.live.tracking.config</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem
        id="menu_tz_live_tracking_config"
        name="Live Tracking Settings"
        parent="tz_crm_base.menu_tz_crm_config"
        action="action_tz_live_tracking_config"
        sequence="95"
        groups="tz_crm_base.group_tz_crm_admin"
    />

</odoo>