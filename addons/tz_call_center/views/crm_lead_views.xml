<odoo>
    <record id="view_crm_lead_form_call_logs" model="ir.ui.view">
        <field name="name">crm.lead.form.call.logs</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_call_logs"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-phone">
                    <field name="call_log_count" widget="statinfo" string="Calls"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>