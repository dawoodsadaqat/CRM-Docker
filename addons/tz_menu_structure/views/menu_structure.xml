<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="crm.crm_menu_root" model="ir.ui.menu">
        <field name="name">CRM</field>
        <field name="sequence">10</field>
        <field name="active" eval="True"/>
    </record>

    <record id="hr.menu_hr_root" model="ir.ui.menu">
        <field name="name">Employees</field>
        <field name="sequence">20</field>
        <field name="active" eval="True"/>
    </record>

    <record id="action_tz_customer_invoices" model="ir.actions.act_window">
        <field name="name">Customer Invoices</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="domain">[('move_type', '=', 'out_invoice')]</field>
        <field name="context">{'default_move_type': 'out_invoice'}</field>
    </record>

    <record id="action_tz_vendor_bills" model="ir.actions.act_window">
        <field name="name">Vendor Bills</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="domain">[('move_type', '=', 'in_invoice')]</field>
        <field name="context">{'default_move_type': 'in_invoice'}</field>
    </record>

    <record id="action_tz_commission_invoices" model="ir.actions.act_window">
        <field name="name">Commission Invoices</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="domain">[('tz_commission_id', '!=', False)]</field>
        <field name="context">{}</field>
    </record>

    <menuitem id="menu_tz_customer_invoices"
              name="Customer Invoices"
              parent="account.menu_finance"
              action="action_tz_customer_invoices"
              sequence="10"/>

    <menuitem id="menu_tz_vendor_bills"
              name="Vendor Bills"
              parent="account.menu_finance"
              action="action_tz_vendor_bills"
              sequence="20"/>

    <menuitem id="menu_tz_commission_invoices"
              name="Commission Invoices"
              parent="account.menu_finance"
              action="action_tz_commission_invoices"
              sequence="30"/>

    <menuitem id="menu_tz_main_payroll"
              name="Payroll"
              sequence="40"/>

    <record id="action_tz_payroll_batches_menu" model="ir.actions.act_window">
        <field name="name">Payroll Batches</field>
        <field name="res_model">tz.payroll</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_tz_payroll_lines_menu" model="ir.actions.act_window">
        <field name="name">Payroll Lines</field>
        <field name="res_model">tz.payroll.line</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_tz_payroll_batches"
              name="Payroll Batches"
              parent="menu_tz_main_payroll"
              action="action_tz_payroll_batches_menu"
              sequence="10"/>

    <menuitem id="menu_tz_payroll_lines"
              name="Payroll Lines"
              parent="menu_tz_main_payroll"
              action="action_tz_payroll_lines_menu"
              sequence="20"/>

    <menuitem id="menu_tz_crm_live_tracking"
              name="Live Tracking"
              parent="crm.crm_menu_root"
              action="tz_live_tracking.action_tz_my_tracking"
              sequence="95"/>

    <record id="action_tz_menu_attendance" model="ir.actions.act_window">
        <field name="name">Attendance</field>
        <field name="res_model">hr.attendance</field>
        <field name="view_mode">tree,form,pivot,graph</field>
    </record>

    <menuitem id="menu_tz_employees_attendance"
              name="Attendance"
              parent="hr.menu_hr_root"
              action="action_tz_menu_attendance"
              sequence="50"/>
<record id="menu_tz_accounting_invoicing" model="ir.ui.menu">
    <field name="active" eval="False"/>
</record>
</odoo>