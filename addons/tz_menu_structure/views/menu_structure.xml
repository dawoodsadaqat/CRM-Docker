<record id="action_tz_menu_attendance" model="ir.actions.act_window">
    <field name="name">Attendance</field>
    <field name="res_model">hr.attendance</field>
    <field name="view_mode">tree,form,pivot,graph</field>
</record>

<record id="action_tz_menu_expenses" model="ir.actions.act_window">
    <field name="name">Expenses</field>
    <field name="res_model">hr.expense</field>
    <field name="view_mode">tree,kanban,form,pivot,graph</field>
</record>

<menuitem id="menu_tz_employees_attendance"
          name="Attendance"
          parent="hr.menu_hr_root"
          action="action_tz_menu_attendance"
          sequence="50"/>

<menuitem id="menu_tz_accounting_expenses"
          name="Expenses"
          parent="menu_tz_main_accounting"
          action="action_tz_menu_expenses"
          sequence="50"/>


