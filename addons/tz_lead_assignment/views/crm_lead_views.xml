<odoo>
    <record id="view_crm_lead_form_assignment" model="ir.ui.view">
        <field name="name">crm.lead.form.assignment</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet//group" position="inside">
                <group string="Lead Assignment">
                    <field name="assignment_rule_id" readonly="1"/>
                    <field name="auto_assigned" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>