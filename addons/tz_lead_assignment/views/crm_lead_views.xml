<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================================================== -->
    <!-- CRM LEAD FORM -->
    <!-- ===================================================== -->

    <record id="view_crm_lead_form_assignment" model="ir.ui.view">
        <field name="name">crm.lead.form.assignment</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='user_id']" position="after">

                <field
                    name="agent_owner_id"
                    options="{'no_create': True}"
                />

            </xpath>

        </field>
    </record>

    <!-- ===================================================== -->
    <!-- CRM LEAD TREE -->
    <!-- ===================================================== -->

    <record id="view_crm_lead_tree_assignment" model="ir.ui.view">
        <field name="name">crm.lead.tree.assignment</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_tree_view_oppor"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='user_id']" position="after">

                <field name="agent_owner_id"/>

            </xpath>

        </field>
    </record>

</odoo>