<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =========================================
         AGENT: ONLY OWN PAYROLL LINES
    ========================================== -->

    <record id="tz_payroll_line_rule_agent" model="ir.rule">
        <field name="name">Payroll Line Own</field>
        <field name="model_id" ref="model_tz_payroll_line"/>
        <field name="domain_force">
            [('employee_id.user_id', '=', user.id)]
        </field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>


    <!-- =========================================
         SUPERVISOR: TEAM PAYROLL LINES
    ========================================== -->

    <record id="tz_payroll_line_rule_supervisor" model="ir.rule">
    <field name="name">Payroll Line Team</field>
    <field name="model_id" ref="model_tz_payroll_line"/>
    <field name="domain_force">
        [
            '|',
            ('employee_id.user_id', '=', user.id),
            ('employee_id.parent_id.user_id', '=', user.id)
        ]
    </field>
    <field name="groups" eval="[(4, ref('hr.group_hr_manager'))]"/>
</record>


    <!-- =========================================
         ADMIN: FULL ACCESS
    ========================================== -->

    <record id="tz_payroll_line_rule_admin" model="ir.rule">
        <field name="name">Payroll Line Admin</field>
        <field name="model_id" ref="model_tz_payroll_line"/>
        <field name="domain_force">
            [(1, '=', 1)]
        </field>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>

</odoo>