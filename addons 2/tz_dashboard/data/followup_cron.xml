<odoo>
    <record id="ir_cron_create_followup_activities" model="ir.cron">
        <field name="name">Create Follow-up Activities</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="state">code</field>
        <field name="code">model._cron_create_followup_activities()</field>
        <field name="interval_number">15</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
    </record>
    <record id="ir_cron_check_rescue_sla" model="ir.cron">
    	<field name="name">Check Rescue SLA</field>
    	<field name="model_id" ref="crm.model_crm_lead"/>
    	<field name="state">code</field>
    	<field name="code">model._cron_check_rescue_sla()</field>
    	<field name="interval_number">10</field>
    	<field name="interval_type">minutes</field>
    	<field name="active">True</field>
    </record>
    <record id="ir_cron_create_sla_warning_reminders" model="ir.cron">
    	<field name="name">Create SLA Warning Reminders</field>
    	<field name="model_id" ref="crm.model_crm_lead"/>
    	<field name="state">code</field>
    	<field name="code">model._cron_create_sla_warning_reminders()</field>
    	<field name="interval_number">10</field>
    	<field name="interval_type">minutes</field>
    	<field name="active">True</field>
    </record>
</odoo>