<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <record id="view_employee_form_tz_hr_extension" model="ir.ui.view">
        <field name="name">hr.employee.form.tz.hr.extension</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet" position="inside">

                <group string="CRM User Setup" groups="hr.group_hr_manager,base.group_system">

                    <group>
                        <field name="tz_is_crm_user"/>
                        <field name="work_email"/>
                    </group>

                    <group>
                        <field name="tz_linked_user_id"
                            readonly="1"
                            options="{'no_open': True}"/>                       
                        <field name="tz_user_login" readonly="1"/>
                    </group>

                    <group>
                        <button name="action_create_or_sync_crm_user"
                                type="object"
                                string="Create / Sync CRM User"
                                class="btn-primary"
                                invisible="not tz_is_crm_user"/>

                        <button name="action_open_user_settings"
                                type="object"
                                string="Open User Settings"
                                class="btn-secondary"
                                invisible="not tz_linked_user_id"/>
                    </group>

                </group>

            </xpath>

        </field>
    </record>


    <record id="view_employee_tree_tz_hr_extension" model="ir.ui.view">
        <field name="name">hr.employee.tree.tz.hr.extension</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_tree"/>
        <field name="arch" type="xml">

            <xpath expr="//tree" position="inside">
                <field name="tz_is_crm_user"/>
                <field name="tz_linked_user_id"/>
                <field name="tz_user_login"/>
            </xpath>

        </field>
    </record>

</odoo>