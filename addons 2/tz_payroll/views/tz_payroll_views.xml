<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <record id="seq_tz_payroll" model="ir.sequence">
        <field name="name">TZ Payroll</field>
        <field name="code">tz.payroll</field>
        <field name="prefix">PAY/%(year)s/</field>
        <field name="padding">4</field>
    </record>

    <record id="view_tz_payroll_tree" model="ir.ui.view">
        <field name="name">tz.payroll.tree</field>
        <field name="model">tz.payroll</field>

        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="state"/>
                <field name="total_net_payable"/>
            </tree>
        </field>
    </record>

    <record id="view_tz_payroll_form" model="ir.ui.view">
        <field name="name">tz.payroll.form</field>
        <field name="model">tz.payroll</field>

        <field name="arch" type="xml">

            <form string="Payroll">

                <header>

                    <button name="action_generate_lines"
                            type="object"
                            string="Generate Payroll Lines"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_confirm"
                            type="object"
                            string="Confirm Payroll"
                            class="btn-success"
                            invisible="state != 'generated'"/>

                    <button name="action_cancel"
                            type="object"
                            string="Cancel"
                            invisible="state == 'cancelled'"/>

                    <button name="action_reset_to_draft"
                            type="object"
                            string="Reset to Draft"
                            invisible="state != 'cancelled'"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,generated,confirmed,cancelled"/>

                </header>

                <sheet>

                    <group>

                        <group>
                            <field name="name" readonly="1"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="company_id"/>
                        </group>

                        <group>
                            <field name="total_basic_salary" readonly="1"/>
                            <field name="total_commission" readonly="1"/>
                            <field name="total_expenses" readonly="1"/>
                            <field name="total_deductions" readonly="1"/>
                            <field name="total_clawbacks" readonly="1"/>
                            <field name="total_net_payable" readonly="1"/>
                        </group>

                    </group>

                    <notebook>

                        <page string="Payroll Lines">

                            <field name="line_ids">

                                <tree editable="bottom">

                                    <field name="employee_id"/>
                                    <field name="user_id"/>

                                    <field name="basic_salary"/>

                                    <field name="commission_amount"/>

                                    <field name="expense_amount"/>

                                    <field name="deduction_amount"/>

                                    <field name="clawback_amount"/>

                                    <field name="net_payable" readonly="1"/>
                                    <field name="payable_bill_id" readonly="1"/>
                                    <field name="payment_state" readonly="1"/>

                                    <button name="action_create_payable_bill"
                                            type="object"
                                            string="Create Payable Bill"
                                            class="btn-primary"
                                            invisible="payable_bill_id"/>

                                    <button name="action_open_payable_bill"
                                            type="object"
                                            string="Open Bill"
                                            class="btn-secondary"
                                            invisible="not payable_bill_id"/>

                                </tree>

                            </field>

                        </page>

                    </notebook>

                </sheet>

                <chatter/>

            </form>

        </field>
    </record>

    <record id="view_tz_payroll_search" model="ir.ui.view">
        <field name="name">tz.payroll.search</field>
        <field name="model">tz.payroll</field>

        <field name="arch" type="xml">

            <search>

                <field name="name"/>

                <field name="date_from"/>

                <field name="date_to"/>

                <filter name="draft"
                        string="Draft"
                        domain="[('state','=','draft')]"/>

                <filter name="confirmed"
                        string="Confirmed"
                        domain="[('state','=','confirmed')]"/>

            </search>

        </field>
    </record>

    <record id="action_tz_payroll" model="ir.actions.act_window">
        <field name="name">Monthly Payrolls</field>
        <field name="res_model">tz.payroll</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_tz_payroll_search"/>
    </record>

    <menuitem id="menu_tz_payroll_root"
              name="Payroll"
              sequence="100"/>

    <menuitem id="menu_tz_payroll"
              name="Monthly Payrolls"
              parent="menu_tz_payroll_root"
              action="action_tz_payroll"
              sequence="1"/>

</odoo>