<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <record id="view_account_move_form_tz_accounting_extension" model="ir.ui.view">

        <field name="name">account.move.form.tz.accounting.extension</field>

        <field name="model">account.move</field>

        <field name="inherit_id" ref="account.view_move_form"/>

        <field name="arch" type="xml">

            <xpath expr="//sheet" position="inside">

                <group string="CRM Accounting Links">

                    <group>

                        <field name="tz_move_purpose" readonly="1"/>

                        <field name="tz_commission_id" readonly="1"/>

                    </group>

                    <group>

                        <field name="tz_lead_id" readonly="1"/>

                        <field name="tz_property_unit_id" readonly="1"/>

                    </group>

                </group>

            </xpath>

        </field>

    </record>

</odoo>