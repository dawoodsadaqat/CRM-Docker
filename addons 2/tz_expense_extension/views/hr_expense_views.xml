<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <record id="view_hr_expense_form_tz_extension" model="ir.ui.view">
        <field name="name">hr.expense.form.tz.extension</field>
        <field name="model">hr.expense</field>
        <field name="inherit_id" ref="hr_expense.hr_expense_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet" position="inside">

                <group string="CRM / Real Estate Links">

                    <group>
                        <field name="lead_id"/>
                        <field name="site_visit_id"/>
                        <field name="property_unit_id"/>
                        <field name="customer_id"/>
                    </group>

                    <group>
                        <field name="is_crm_expense" readonly="1"/>
                        <field name="supervisor_approval_state" readonly="1"/>
                        <field name="approved_by_supervisor_id" readonly="1"/>
                    </group>

                </group>

                <group string="Supervisor Review">
                    <field name="supervisor_rejection_reason"/>
                </group>

                <group string="CRM Expense Actions">
                    <button name="action_submit_to_supervisor"
                            type="object"
                            string="Submit to Supervisor"
                            class="btn-primary"
                            invisible="supervisor_approval_state != 'draft'"/>

                    <button name="action_supervisor_approve"
                            type="object"
                            string="Supervisor Approve"
                            class="btn-success"
                            invisible="supervisor_approval_state != 'submitted'"/>

                    <button name="action_supervisor_reject"
                            type="object"
                            string="Supervisor Reject"
                            class="btn-danger"
                            invisible="supervisor_approval_state != 'submitted'"/>

                    <button name="action_view_linked_lead"
                            type="object"
                            string="Open Lead"
                            class="btn-secondary"
                            invisible="not lead_id"/>

                    <button name="action_view_site_visit"
                            type="object"
                            string="Open Site Visit"
                            class="btn-secondary"
                            invisible="not site_visit_id"/>

                    <button name="action_view_property_unit"
                            type="object"
                            string="Open Property"
                            class="btn-secondary"
                            invisible="not property_unit_id"/>
                </group>

            </xpath>

        </field>
    </record>


    <record id="view_hr_expense_tree_tz_extension" model="ir.ui.view">
        <field name="name">hr.expense.tree.tz.extension</field>
        <field name="model">hr.expense</field>
        <field name="inherit_id" ref="hr_expense.view_expenses_tree"/>
        <field name="arch" type="xml">

            <xpath expr="//tree" position="inside">
                <field name="lead_id" optional="show"/>
                <field name="site_visit_id" optional="hide"/>
                <field name="property_unit_id" optional="show"/>
                <field name="customer_id" optional="show"/>
                <field name="supervisor_approval_state" optional="show"/>
                <field name="approved_by_supervisor_id" optional="hide"/>
            </xpath>

        </field>
    </record>

</odoo>