<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_tz_role_module_access_tree" model="ir.ui.view">
        <field name="name">tz.role.module.access.tree</field>
        <field name="model">tz.role.module.access</field>
        <field name="arch" type="xml">
            <tree>
                <field name="role_group_id"/>
                <field name="feature_ids" widget="many2many_tags"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_tz_role_module_access_form" model="ir.ui.view">
        <field name="name">tz.role.module.access.form</field>
        <field name="model">tz.role.module.access</field>
        <field name="arch" type="xml">
            <form string="Role Module Access">
                <header>
                    <button name="action_apply_access" type="object" string="Apply Access To Role" class="btn-primary"/>
                    <button name="action_reapply_menu_security" type="object" string="Reapply Menu Security" class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <field name="role_group_id"/>
                        <field name="active"/>
                    </group>
                    <group string="Allowed Modules / Submodules">
                        <field name="feature_ids" widget="many2many_checkboxes" nolabel="1"/>
                    </group>
                    <group string="Technical Groups Applied">
                        <field name="mapped_group_ids" widget="many2many_tags" readonly="1"/>
                    </group>
                    <p class="text-muted">
                        Select a CRM role, choose allowed modules/submodules, click Apply Access To Role, then Reapply Menu Security.
                        Affected users must logout/login again.
                    </p>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tz_role_module_access" model="ir.actions.act_window">
        <field name="name">Role Module Access</field>
        <field name="res_model">tz.role.module.access</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_tz_module_feature_tree" model="ir.ui.view">
        <field name="name">tz.module.feature.tree</field>
        <field name="model">tz.module.feature</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence"/>
                <field name="name"/>
                <field name="code"/>
                <field name="category"/>
                <field name="technical_group_id"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_tz_module_feature_form" model="ir.ui.view">
        <field name="name">tz.module.feature.form</field>
        <field name="model">tz.module.feature</field>
        <field name="arch" type="xml">
            <form string="Module/Submodule Feature">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="category"/>
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="technical_group_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="menu_xml_ids" widget="text"/>
                            <field name="menu_name_keywords" widget="text"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tz_module_feature" model="ir.actions.act_window">
        <field name="name">Module/Submodule Features</field>
        <field name="res_model">tz.module.feature</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
