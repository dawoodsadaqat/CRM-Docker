<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_tz_user_location_tree" model="ir.ui.view">
        <field name="name">tz.user.location.tree</field>
        <field name="model">tz.user.location</field>
        <field name="arch" type="xml">
            <tree string="User Locations">
                <field name="user_id"/>
                <field name="latitude"/>
                <field name="longitude"/>
                <field name="accuracy"/>
                <field name="battery_level"/>
                <field name="last_seen"/>
                <field name="supervisor_id"/>
                <button
                    name="action_open_map"
                    type="object"
                    string="Open Map"
                    class="btn-primary"/>
            </tree>
        </field>
    </record>

    <record id="view_tz_user_location_form" model="ir.ui.view">
        <field name="name">tz.user.location.form</field>
        <field name="model">tz.user.location</field>
        <field name="arch" type="xml">
            <form string="User Location">
                <header>
                    <button
                        name="action_open_map"
                        type="object"
                        string="Open in Google Maps"
                        class="btn-primary"/>
                </header>

                <sheet>
                    <group>
                        <field name="user_id"/>
                        <field name="latitude"/>
                        <field name="longitude"/>
                        <field name="accuracy"/>
                        <field name="battery_level"/>
                        <field name="last_seen"/>
                        <field name="supervisor_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tz_user_location" model="ir.actions.act_window">
        <field name="name">Team / User Locations</field>
        <field name="res_model">tz.user.location</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="view_tz_user_location_history_tree" model="ir.ui.view">
        <field name="name">tz.user.location.history.tree</field>
        <field name="model">tz.user.location.history</field>
        <field name="arch" type="xml">
            <tree string="Location History">
                <field name="user_id"/>
                <field name="latitude"/>
                <field name="longitude"/>
                <field name="accuracy"/>
                <field name="battery_level"/>
                <field name="tracked_at"/>
                <field name="supervisor_id"/>
                <button
                    name="action_open_map"
                    type="object"
                    string="Open Map"
                    class="btn-primary"/>
            </tree>
        </field>
    </record>

    <record id="view_tz_user_location_history_form" model="ir.ui.view">
        <field name="name">tz.user.location.history.form</field>
        <field name="model">tz.user.location.history</field>
        <field name="arch" type="xml">
            <form string="Location History">
                <header>
                    <button
                        name="action_open_map"
                        type="object"
                        string="Open in Google Maps"
                        class="btn-primary"/>
                </header>

                <sheet>
                    <group>
                        <field name="user_id"/>
                        <field name="latitude"/>
                        <field name="longitude"/>
                        <field name="accuracy"/>
                        <field name="battery_level"/>
                        <field name="tracked_at"/>
                        <field name="supervisor_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tz_user_location_history" model="ir.actions.act_window">
        <field name="name">Location History</field>
        <field name="res_model">tz.user.location.history</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>