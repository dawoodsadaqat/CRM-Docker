<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="res_config_settings_view_form_tz_i18n_support" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.tz.i18n.support</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Techzilla Multilingual" name="tz_i18n_support">
                    <block title="Multilingual CRM Settings">
                        <setting string="Enable Multilingual CRM" help="Enable multilingual behavior for Techzilla CRM custom modules.">
                            <field name="tz_enable_multilingual_crm"/>
                        </setting>
                        <setting string="Default CRM Language" help="Default language preference for CRM users.">
                            <field name="tz_default_language_code"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
