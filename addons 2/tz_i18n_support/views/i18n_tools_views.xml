<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_tz_i18n_tools_form" model="ir.ui.view">
        <field name="name">tz.i18n.tools.form</field>
        <field name="model">tz.i18n.tools</field>
        <field name="arch" type="xml">
            <form string="Translation Tools">
                <sheet>
                    <group>
                        <field name="language_code"/>
                        <field name="module_scope"/>
                        <field name="custom_module_list" readonly="1" widget="text"/>
                        <field name="note"/>
                    </group>
                    <footer>
                        <button name="action_open_languages" type="object" string="Open Languages" class="btn-primary"/>
                        <button name="action_open_translations" type="object" string="Open Translated Terms" class="btn-secondary"/>
                        <button name="action_show_export_instructions" type="object" string="Show Export Command" class="btn-secondary"/>
                        <button string="Close" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_tz_i18n_tools" model="ir.actions.act_window">
        <field name="name">Translation Tools</field>
        <field name="res_model">tz.i18n.tools</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
    <menuitem id="menu_tz_i18n_root" name="Multilingual" parent="base.menu_administration" sequence="90" groups="base.group_system"/>
    <menuitem id="menu_tz_i18n_tools" name="Translation Tools" parent="menu_tz_i18n_root" action="action_tz_i18n_tools" sequence="10" groups="base.group_system"/>
</odoo>
