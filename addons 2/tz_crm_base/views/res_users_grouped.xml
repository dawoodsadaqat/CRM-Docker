<odoo>

    <record id="view_users_search_grouped" model="ir.ui.view">
        <field name="name">res.users.search.grouped</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_search"/>
        <field name="arch" type="xml">

            <xpath expr="//search" position="inside">

                <!-- Managers -->
                <filter string="Managers"
                        name="filter_managers"
                        domain="[('groups_id.name', 'ilike', 'Manager')]"/>

                <!-- Agents -->
                <filter string="Agents"
                        name="filter_agents"
                        domain="[('groups_id.name', 'ilike', 'Agent')]"/>

            </xpath>

        </field>
    </record>

</odoo>