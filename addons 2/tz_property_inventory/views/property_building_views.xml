<odoo>
    <record id="view_tz_property_building_tree" model="ir.ui.view">
        <field name="name">tz.property.building.tree</field>
        <field name="model">tz.property.building</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="project_id"/>
                <field name="developer_id"/>
                <field name="city"/>
                <field name="area"/>
                <field name="address"/>
                <field name="floors"/>
                <field name="unit_count"/>
            </tree>
        </field>
    </record>

    <record id="view_tz_property_building_form" model="ir.ui.view">
        <field name="name">tz.property.building.form</field>
        <field name="model">tz.property.building</field>
        <field name="arch" type="xml">
            <form string="Property Building">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="project_id"/>
                            <field name="developer_id" readonly="1"/>
                            <field name="city" readonly="1"/>
                            <field name="area" readonly="1"/>
                        </group>
                        <group>
                            <field name="address"/>
                            <field name="floors"/>
                            <field name="unit_count" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Amenities">
                            <field name="amenities"/>
                        </page>

                        <page string="Units">
                            <field name="unit_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="unit_number"/>
                                    <field name="property_type"/>
                                    <field name="bedrooms"/>
                                    <field name="sale_price"/>
                                    <field name="rent_price"/>
                                    <field name="availability"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tz_property_building_search" model="ir.ui.view">
        <field name="name">tz.property.building.search</field>
        <field name="model">tz.property.building</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="project_id"/>
                <field name="developer_id"/>
                <field name="area"/>

                <group expand="0" string="Group By">
                    <filter string="Project" name="group_project" context="{'group_by':'project_id'}"/>
                    <filter string="Area" name="group_area" context="{'group_by':'area'}"/>
                    <filter string="Developer" name="group_developer" context="{'group_by':'developer_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_tz_property_building" model="ir.actions.act_window">
        <field name="name">Buildings</field>
        <field name="res_model">tz.property.building</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_tz_property_building_search"/>
    </record>
</odoo>