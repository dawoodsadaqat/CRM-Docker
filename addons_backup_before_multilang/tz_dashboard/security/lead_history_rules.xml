<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ADMIN -->

    <record id="rule_tz_lead_history_admin" model="ir.rule">
        <field name="name">Lead History Admin</field>
        <field name="model_id" ref="model_tz_lead_history"/>
        <field name="groups"
               eval="[(4, ref('tz_crm_base.group_tz_crm_admin'))]"/>
        <field name="domain_force">[(1,'=',1)]</field>
    </record>

    <!-- SUPERVISOR / MANAGER -->

    <record id="rule_tz_lead_history_manager" model="ir.rule">
        <field name="name">Lead History Manager</field>
        <field name="model_id" ref="model_tz_lead_history"/>
        <field name="groups"
               eval="[(4, ref('tz_crm_base.group_tz_crm_manager'))]"/>

        <field name="domain_force">
            [
                '|',
                    ('supervisor_id', '=', user.id),
                    ('team_id.member_ids', 'in', [user.id])
            ]
        </field>
    </record>

    <!-- AGENT -->

    <record id="rule_tz_lead_history_agent" model="ir.rule">
    <field name="name">Lead History Agent</field>
    <field name="model_id" ref="model_tz_lead_history"/>
    <field name="groups" eval="[(4, ref('tz_crm_base.group_tz_crm_agent'))]"/>
    <field name="domain_force">
        [
            '|', '|', '|', '|',
                ('visible_agent_ids', 'in', [user.id]),
                ('new_agent_id', '=', user.id),
                ('old_agent_id', '=', user.id),
                ('performed_by_id', '=', user.id),
                ('lead_id.agent_owner_id', '=', user.id)
        ]
    </field>
</record>

</odoo>