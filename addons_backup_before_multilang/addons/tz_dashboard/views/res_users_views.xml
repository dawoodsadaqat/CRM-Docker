<odoo>
    <record id="view_users_form_supervisor" model="ir.ui.view">
        <field name="name">res.users.form.supervisor</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">

            <!-- Inject into Preferences tab (SAFE location) -->
            <xpath expr="//page[@name='preferences']" position="inside">
                <group string="Management">
                    <field name="supervisor_id"/>
                </group>
            </xpath>

        </field>
    </record>
</odoo>