<odoo>
    <record id="view_tz_lead_category_tree" model="ir.ui.view">
        <field name="name">tz.lead.category.tree</field>
        <field name="model">tz.lead.category</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_tz_lead_category_form" model="ir.ui.view">
        <field name="name">tz.lead.category.form</field>
        <field name="model">tz.lead.category</field>
        <field name="arch" type="xml">
            <form string="Lead Category">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tz_lead_category" model="ir.actions.act_window">
        <field name="name">Lead Categories</field>
        <field name="res_model">tz.lead.category</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_tz_lead_category"
              name="Lead Categories"
              parent="crm.crm_menu_root"
              action="action_tz_lead_category"
              groups="tz_crm_base.group_tz_crm_manager,tz_crm_base.group_tz_crm_admin"
              sequence="95"/>
</odoo>