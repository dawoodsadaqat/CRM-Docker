<odoo>

    <!-- Pipeline / Opportunities Search View -->
    <record id="view_crm_opportunity_filter_category" model="ir.ui.view">
        <field name="name">crm.opportunity.search.category</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.view_crm_case_opportunities_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <filter string="Category"
                        name="group_by_lead_category_opportunity"
                        context="{'group_by':'lead_category_id'}"/>
            </xpath>
        </field>
    </record>

    <!-- Leads Search View -->
    <record id="view_crm_lead_filter_category" model="ir.ui.view">
        <field name="name">crm.lead.search.category</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.view_crm_case_leads_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <filter string="Category"
                        name="group_by_lead_category_lead"
                        context="{'group_by':'lead_category_id'}"/>
            </xpath>
        </field>
    </record>

</odoo>