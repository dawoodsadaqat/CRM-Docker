<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="tz_live_tracking.LiveTrackingPanel">
        <div class="p-4">
            <div class="card shadow-sm p-4" style="max-width: 700px;">
                <h2 class="mb-3">My Live Tracking</h2>

                <p class="text-muted">
                    Start tracking from your own browser or mobile device.
                </p>

                <div class="mt-3">
                    <button class="btn btn-success me-2" t-on-click="startTracking">
                        Start Tracking
                    </button>

                    <button class="btn btn-danger" t-on-click="stopTracking">
                        Stop Tracking
                    </button>
                </div>

                <hr/>

                <div class="mt-3">
                    <p><strong>Status:</strong> <span t-esc="state.status"/></p>
                    <p><strong>Latitude:</strong> <span t-esc="state.latitude"/></p>
                    <p><strong>Longitude:</strong> <span t-esc="state.longitude"/></p>
                    <p><strong>Accuracy:</strong> <span t-esc="state.accuracy"/></p>
                    <p><strong>Last Sent:</strong> <span t-esc="state.lastSent"/></p>
                </div>
            </div>
        </div>
    </t>

</templates>