<odoo>
    <!-- Add Source Channel to Leads/Opportunities list -->
    <record id="view_crm_lead_tree_source_channel" model="ir.ui.view">
        <field name="name">crm.lead.tree.source.channel</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_tree_view_leads"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="source_channel" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- Add Source filter/group in Leads search -->
    <record id="view_crm_lead_search_source_channel" model="ir.ui.view">
        <field name="name">crm.lead.search.source.channel</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.view_crm_case_leads_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <separator/>

                <filter string="Manual"
                        name="source_manual"
                        domain="[('source_channel','=','manual')]"/>

                <filter string="Meta"
                        name="source_meta"
                        domain="[('source_channel','=','meta')]"/>

                <filter string="WhatsApp"
                        name="source_whatsapp"
                        domain="[('source_channel','=','whatsapp')]"/>

                <filter string="Website"
                        name="source_website"
                        domain="[('source_channel','=','website')]"/>

                <group expand="0" string="Group By">
                    <filter string="Source"
                            name="group_by_source_channel"
                            context="{'group_by':'source_channel'}"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>